    printf("Name: %s\n", s1.name);
    printf("Salary: %.2f\n", s1.salary);
    return 0;
}

\\Using Typedef for an integer array of size 5 read and print he elements

#include <stdio.h>
typedef int AR[5]; 
int main() {
    AR arr;
    int i;
    for (i = 0; i < 5; i++) {
        printf("Enter element: ");
        scanf("%d", &arr[i]);
    }
    printf("Elements are:\n");
    for (i = 0; i < 5; i++) {
        printf("%d\n", arr[i]);
    }
     return 0;
}



