\\Using Typedef to create a structure to display the details of one student

#include <stdio.h>
typedef struct {
    int roll_no;
    char name[50]; // Fixed: Reserved space for up to 49 characters + null terminator
    float marks;
} Student;

int main() {
    Student s1;
    printf("Enter Roll Number: ");
    scanf("%d", &s1.roll_no);
    printf("Enter Name: ");
    scanf("%s", s1.name);
    printf("Enter Marks: ");
    scanf("%f", &s1.marks);
    printf("Roll No: %d\n", s1.roll_no);
    printf("Name: %s\n", s1.name);
    printf("Marks: %.2f\n", s1.marks);
    return 0;
}

\\Using Typedef to create a structure to display the details of one employee

#include <stdio.h>
typedef struct {
    int id_no;
    char name[50]; // Fixed: Reserved space for up to 49 characters + null terminator
    float salary;
} Employee;

int main() {
    Employee s1;
    printf("Enter id Number: ");
    scanf("%d", &s1.id_no);
    printf("Enter Name: ");
