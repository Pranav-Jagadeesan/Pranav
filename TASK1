//PALINDROME CHECKING
#include <stdio.h>

int main() {
    int n, m, reverse= 0, r;

    printf("Enter an integer: ");
    scanf("%d", &n);
    m = n;
    while (n != 0) {
        r = n % 10;
        reverse = reverse * 10 + r;
        n/= 10;
    }
    if (m == reverse) {
        printf("%d palindrome\n", m);
    } else {
        printf("%d  not a palindrome\n", m);
    }
    return 0;
}

