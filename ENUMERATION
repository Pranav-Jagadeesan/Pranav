\\ENUMERATION FOR DIRECTIONS  AND DISPLAY MESSAGE BASED ON USER CHOICE
#include <stdio.h>
enum Directions {
    NORTH = 1,
    EAST,
    SOUTH,
    WEST
};

int main() {
    int c;
    printf("Enter 1-4: ");
    scanf("%d", &c);
	switch (c) {
        case NORTH:
            printf("NORTH %d\n", NORTH);
            break;
        case EAST:
            printf("EAST %d\n", EAST);
            break;
        case SOUTH:
            printf("SOUTH %d\n", SOUTH);
            break;
        case WEST:
            printf("WEST %d\n", WEST);
            break;
        default:
            printf("Invalid\n");
            break;
    }

    return 0;
}
