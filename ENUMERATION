\\ENUMERATION FOR COLORS ACCEPT VALUE FROM USER AND DISPLAYING CORRESPONDING COLOR
#include <stdio.h>
enum Colors {
    R,
    B,
    G
};

int main() {
    int i;
    printf("Enter a number (0 for RED, 1 for BLUE, 2 for GREEN): ");
    scanf("%d", &i);
  switch (i) {
        case R:
            printf("You chose RED\n");
            break;
        case B:
            printf("You chose BLUE\n");
            break;
        case G:
            printf("You chose GREEN\n");
            break;
        default:
            printf("Invalid");
            break;
    }

    return 0;
}

