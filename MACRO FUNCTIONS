\\SQUARE OF A NUMBER
#include <stdio.h>
#define square(x) ((x) * (x))
int main() 
{
    int y;
    int z;
    printf("ENTER A NUMBER:  ");
    scanf("%d", &z);
    y = square(z);
    printf("The square is: %d\n", y); 
    return 0;
}

