\\DISPLAYING WHETHER THE NUMBER IS EVEN OR ODD

#include <stdio.h>
#define check(n) ((n) % 2 == 0)
int main() {
    int i;

    printf("Enter a number: \n");
    scanf("%d", &i);
    if (check(i)) {
        printf("Even number \n");
    } else {
        printf("Odd number \n");
    }

    return 0;
}

\\CELCIUS TO FARENHEIT CONVERSION


#include <stdio.h>
#define convert(c) ((c)*9/5+32)
int main() {
    int e;
    int f;

    printf("Enter temperature in celcius: \n");
    scanf("%d", &e);
    printf("Celcius: %d  \n",e);
    f=convert(e);
    printf("Farenheit: %d   \n",f);
    return 0;
}

